{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  },
  "extensions": {
    "queues": {
      "messageEncoding": "base64"
    }
  },
    "functionTimeout": "00:10:00",
    "extensions": {
      "queues": {
        "visibilityTimeout": "00:10:00",
        "batchSize": 1,
        "newBatchThreshold": 0,
        "maxDequeueCount": 5
      }
  }
}
